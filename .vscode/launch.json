{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Gateway (debug)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.gateway.app:app",
        "--host", "0.0.0.0",
        "--port", "8001",
        "--workers", "1"
      ],
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend"
      },
      "envFile": "${workspaceFolder}/.env",
      "jinja": true,
      "justMyCode": false,
      "preLaunchTask": "Start Nginx",
      "presentation": {
        "group": "services",
        "order": 1
      }
    }
  ]
}
